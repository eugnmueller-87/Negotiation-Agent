# .env.example — documents every env var; holds NO real values.
# Copy to .env (git-ignored) and fill in. NEVER commit .env.
# In code, read these via os.getenv("NAME") — never hardcode the value.
#
# NOTE: v0 (envelope + value + engine + simulator) is pure Python and needs NO
# secrets. These vars light up only when the LLM extraction/classification layer
# is added. Keep this file in sync with the actual os.getenv() calls in the code.

# ─── LLM provider (extraction / classification layer — not wired yet) ───
# The planned provider is Anthropic (Claude). Confirm current model ids via the
# claude-api skill before pinning one in code — never hardcode a model id inline.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── App config (non-secret defaults are fine to commit here) ───────────
LOG_LEVEL=INFO
ENV=development
